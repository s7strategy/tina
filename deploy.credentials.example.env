# Copie para deploy.credentials.env e coloque a senha SSH do root no VPS.
# deploy.credentials.env está no .gitignore — NÃO vai para o Git.
# Não cole a senha em chats nem em ficheiros partilhados; só neste ficheiro na tua máquina.
#
#   cp deploy.credentials.example.env deploy.credentials.env
#   # edite deploy.credentials.env:
#
# Opcional:
# TINA_VPS_HOST=root@187.77.59.83
# TINA_VPS_DIR=/var/www/tina1

SSHPASS=
